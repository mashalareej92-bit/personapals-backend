# Hugging Face Spaces runs this Docker container.
# Your app must listen on port 7860 (HF's default).
FROM python:3.11-slim

# Create a non-root user (HF Spaces requirement)
RUN useradd -m -u 1000 user
USER user
ENV PATH="/home/user/.local/bin:$PATH"

WORKDIR /app

# Install dependencies first (better build caching)
COPY --chown=user ./requirements.txt requirements.txt
RUN pip install --no-cache-dir --upgrade -r requirements.txt

# Copy the rest of the app
COPY --chown=user . /app

# SQLite lives in /tmp because that's the only writable path on HF Spaces.
# (Note: /tmp is wiped between restarts — fine for a demo.)
ENV DATABASE_URL="sqlite:////tmp/personapals.db"

# Start FastAPI on port 7860
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "7860"]